            <section id="galerie-statica">
                <h2>Galerie</h2>
                <div id="grid-galerie">
                    <% const vectLuni=["ianuarie", "februarie" , "martie" , "aprilie" , "mai" , "iunie" , "iulie"
                        , "august" , "septembrie" , "octombrie" , "noiembrie" , "decembrie" ]; 
                        const lunaCurenta=vectLuni[new Date().getMonth()]; 
                        let imaginiFiltrate=locals.imagini.filter(imag=>imag.luni && imag.luni.includes(lunaCurenta));

                        const maxImages = 12;
                        imaginiFiltrate = imaginiFiltrate.slice(0, maxImages);

                        function getFileNameFromPath(filePath) {
                            if (!filePath) return "imagine";
                            const parts = filePath.split('/');
                            const fileName = parts[parts.length - 1];
                            return fileName.replace(/\.[^/.]+$/, "");
                        }
                        /*12 imagini max => 8x3*/
                        const rows = 8;
                        const cols = 3;
                        let grid = Array(rows).fill().map(() => Array(cols).fill(null));
                        let imgIndex = 0;
                        for (let r = 0; r < rows && imgIndex < imaginiFiltrate.length; r++) { 
                            for (let c=0; c < cols && imgIndex < imaginiFiltrate.length; c++) { 
                                if ((r + c) % 2===0) {
                                grid[r][c]=imaginiFiltrate[imgIndex]; imgIndex++; } 
                            } 
                        } 
                        for (let r=0; r < rows; r++) { 
                            for (let c=0; c < cols; c++) { 
                                const image=grid[r][c]; 
                                if (image) { 
                                    let altText=image.alt; 
                                    if(!altText || altText.trim()==="" ) { altText=getFileNameFromPath(image.fisier); } %>
                            <figure>
                                <picture>
                                    <source srcset="<%- image.fisier_mediu %>" media="(max-width:1100px)">
                                    <img src="<%- image.fisier %>" alt="<%- altText %>" title="<%- image.descriere %>">
                                </picture>
                                <figcaption><%- image.descriere %></figcaption>
                            </figure>
                            <% } else { %>
                                <div class="empty-cell"></div>
                                <% } } } %>
                </div>
            </section>
